# Copy this file to  spike/.env  and fill in ONE provider's values.
# spike/.env is gitignored — your key is never committed.

# ── Option A: Anthropic (production target) ────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# optional model overrides (defaults: convert=claude-opus-4-8, judge=claude-opus-4-8)
# CONVERT_MODEL=claude-opus-4-8

# ── Option B: cheap OpenAI-compatible (OpenAI / OpenRouter / DeepSeek / Groq) ──
# LLM_PROVIDER=openai
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # omit for api.openai.com
# CONVERT_MODEL=gpt-4o-mini
# JUDGE_MODEL=gpt-4o-mini
