# Copy this file to web/.env (local) or set these in your hosting provider's
# dashboard (production). web/.env is gitignored — nothing here is committed.
#
# These vars are read by the running Next.js process at runtime — the
# htmlcollab-app package (../app) is imported as a library, and process.env is
# process-wide, so the LLM_PROVIDER/*_API_KEY vars below must live HERE, not
# just in app/.env.

# ── Auth (required) ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=              # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # production: https://viscollab.niratpatel.com

# ── Database ───────────────────────────────────────────────────────────────────
# Required in production (Vercel's filesystem is ephemeral per instance, so the
# local-JSON-file fallback in src/app/api/collab/db.ts does not work there).
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── LLM provider (required for real AI conversion/edits; without a detected
#    key, the edit/regenerate routes fall back to a deterministic simulation
#    and label the result "Simulated") ────────────────────────────────────────

# Option A: Anthropic
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# CONVERT_MODEL=claude-sonnet-4-6
# EDIT_MODEL=claude-haiku-4-5
# JUDGE_MODEL=claude-sonnet-4-6

# Option B: OpenRouter (cheap/free models — good for a public-facing deploy so
# anonymous traffic doesn't burn Anthropic credits).
# IMPORTANT: LLM_PROVIDER must still say "openai" below — OpenRouter is reached
# via the OpenAI-compatible wire format, selected by OPENAI_BASE_URL, not by a
# provider-specific LLM_PROVIDER value ("openrouter" here silently falls back
# to the anthropic path and breaks).
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Model IDs on OpenRouter are always "vendor/model" (e.g. openai/gpt-4o-mini,
# google/gemini-2.0-flash-001, meta-llama/llama-3.1-8b-instruct) — see
# https://openrouter.ai/models. A bare "gpt-4o-mini" will 400.
# CONVERT_MODEL=openai/gpt-4o-mini
# EDIT_MODEL=openai/gpt-4o-mini
# JUDGE_MODEL=openai/gpt-4o-mini

# ── Optional daily per-user rate limits (defaults: 5 conversions, 10 edits) ──
# MAX_DAILY_CONVERSIONS=5
# MAX_DAILY_EDITS=10

# ── Test-only — NEVER set in production ──────────────────────────────────────
# PLAYWRIGHT_TEST=true
# MOCK_AI=true
